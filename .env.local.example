# LOCAL DEVELOPMENT ONLY
# DO NOT USE IN PRODUCTION
# DO NOT PUT REAL SECRETS
#
# Usage:
#   cp .env.local.example .env.local
#   edit .env.local with local-safe values

# --- Auth bootstrap (local dev) ---
AUTH_ENABLED=true
AUTH_TOKEN_SECRET=CHANGE_ME_LOCAL_ONLY
ROOT_ADMIN_USERNAME=root
ROOT_ADMIN_PASSWORD=CHANGE_ME_LOCAL_ONLY
ROOT_ADMIN_FORCE_SYNC=true
STARTUP_BOOTSTRAP_ENABLED=true

# --- Local runtime mode ---
# REDIS_DISABLED=true + CASE_STORE_BACKEND=database lets local API run without Redis.
REDIS_DISABLED=true
CASE_STORE_BACKEND=database

# --- Proxy (China dev) ---
# If you're behind the GFW, set your local proxy so urllib can reach
# GitHub / DeepSeek / Gitee / GitCode APIs.
# HTTP_PROXY=http://127.0.0.1:7897
# HTTPS_PROXY=http://127.0.0.1:7897

# --- Search / Recommend providers ---
# GitHub token improves rate limits (unauthenticated: 10 req/min).
# GITHUB_TOKEN=ghp_CHANGE_ME
# GITEE_TOKEN=CHANGE_ME
# GITCODE_TOKEN=CHANGE_ME

# --- Search tuning ---
# RECOMMEND_PROVIDER_TIMEOUT_SECONDS=8
# RECOMMEND_TOP_K=20
# DEEP_SEARCH_POINTS_COST=50

# --- OpenClaw (deep doc fetch, optional) ---
# OPENCLAW_BASE_URL=http://127.0.0.1:18789
# OPENCLAW_TIMEOUT_SECONDS=30

# --- LLM / AI (local dev) ---
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-CHANGE_ME
# OPENAI_API_KEY=sk-YOUR_DEEPSEEK_KEY
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# --- Billing health expectations ---
# PAYMENT_PROVIDER=mock is the recommended local default.
PAYMENT_PROVIDER=mock
# If this key is missing, /health/billing may report config=error in local checks.
PAYMENT_WEBHOOK_SECRET=CHANGE_ME_LOCAL_ONLY
